<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>明月大六壬 | 后天八卦活盘</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<script src="https://cdn.tailwindcss.com"></script>
<style>
  body { background: linear-gradient(135deg, #0a0a0a, #1a120b); color: #d4af37; font-family: serif; }
  .ancient { text-shadow: 0 0 10px #d4af37; }
</style>
</head>
<body class="min-h-screen p-6">
  <div class="max-w-xl mx-auto bg-black/80 p-8 rounded-2xl border border-amber-700 text-center">
    <h1 class="text-4xl font-bold ancient mb-2">明月大六壬</h1>
    <p class="text-amber-300 mb-8">明朝帝师秘法 · 一课断财运</p>

    <input id="q" placeholder="请输入您的问题（例如：今日可买币吗？）" class="w-full bg-transparent border-b border-amber-500 p-4 text-lg focus:outline-none">
    <button onclick="start()" class="bg-amber-700 hover:bg-amber-600 w-full py-4 mt-4 rounded-xl text-white text-xl font-bold">起课</button>

    <div id="res" class="hidden mt-8">
      <canvas id="disk" width="300" height="300" class="mx-auto border border-amber-500"></canvas>
      <p id="text" class="mt-6 text-lg leading-relaxed"></p>
    </div>
  </div>

  <script>
  function start() {
    document.getElementById('res').classList.remove('hidden');
    document.getElementById('text').innerHTML = '课象：子将加临，青龙乘财<br>三传：子 → 寅 → 午<br>基础断语：今日财星明亮，宜进不宜退（古法简断）';

    const c = document.getElementById('disk').getContext('2d');
    c.clearRect(0,0,300,300);
    c.strokeStyle = '#d4af37'; c.lineWidth = 4;
    c.beginPath(); c.arc(150,150,130,0,Math.PI*2); c.stroke();
    c.fillStyle = '#d4af37'; c.font = 'bold 24px serif';
    c.fillText('明月盘', 90, 160);
  }
  </script>
</body>
</html>
